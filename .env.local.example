# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Anthropic
ANTHROPIC_API_KEY=

# Gupshup WhatsApp
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE_NUMBER=

# Apify
APIFY_API_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel — custom domains for school careers portals
# 1. Create a token in Vercel dashboard → Account Settings → Tokens
# 2. Copy project ID and team ID from Vercel project settings
# 3. Set VERCEL_TOKEN, VERCEL_PROJECT_ID, VERCEL_TEAM_ID in BOTH Vercel project env
#    AND Convex env (npx convex env set ...)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Vercel Edge Config — middleware host→slug lookup
# Vercel dashboard → Storage → Create Edge Config → link to project (auto-injects EDGE_CONFIG)
# Generate a write token for Convex to update the config: set as EDGE_CONFIG_ID + EDGE_CONFIG_TOKEN in Convex env.
EDGE_CONFIG=
EDGE_CONFIG_ID=
EDGE_CONFIG_TOKEN=
