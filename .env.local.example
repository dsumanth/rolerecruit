# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Better Auth (also set as Convex env vars via `bunx convex env set`)
# BETTER_AUTH_SECRET=<openssl rand -hex 32> — set in Convex only, not here
# SITE_URL=http://localhost:3000 — set in Convex only, not here

# LLM provider: Gemini 2.5 Flash-Lite via OpenAI-compatible endpoint.
# Get a key at https://aistudio.google.com/apikey
# Also set as Convex env var via `bunx convex env set GOOGLE_API_KEY ...`
GOOGLE_API_KEY=

# Meta WhatsApp Cloud API (server-side; also set in Convex via `bunx convex env set`)
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
META_GRAPH_API_VERSION=v22.0
META_WEBHOOK_VERIFY_TOKEN=
# AES-256-GCM key for encrypting per-school access tokens. Generate with: openssl rand -base64 32
# Set in Convex env ONLY (bunx convex env set WHATSAPP_ENCRYPTION_KEY ...), never client-side.
WHATSAPP_ENCRYPTION_KEY=

# Embedded Signup (browser-side FB SDK)
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=

# Apify
APIFY_API_TOKEN=

# Resend (also set as Convex env var)
RESEND_API_KEY=

# Inbound email domain candidates reply to (MX must point at Resend).
# Outbound messages set Reply-To: reply+<token>@$REPLY_INBOUND_DOMAIN so
# replies route through /email/inbound for conversation-agent threading.
# Default if unset: reply.rolerecruit.com
REPLY_INBOUND_DOMAIN=

# Public-facing app URL the conversation agent puts in reschedule booking links.
# Default if unset: https://rolerecruit.com
PUBLIC_BASE_URL=

# Vercel — custom domains for school careers portals
# 1. Create a token in Vercel dashboard → Account Settings → Tokens
# 2. Copy project ID and team ID from Vercel project settings
# 3. Set VERCEL_TOKEN, VERCEL_PROJECT_ID, VERCEL_TEAM_ID in BOTH Vercel project env
#    AND Convex env (bunx convex env set ...)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Vercel Edge Config — middleware host→slug lookup
# Vercel dashboard → Storage → Create Edge Config → link to project (auto-injects EDGE_CONFIG)
# Generate a write token for Convex to update the config: set as EDGE_CONFIG_ID + EDGE_CONFIG_TOKEN in Convex env.
EDGE_CONFIG=
EDGE_CONFIG_ID=
EDGE_CONFIG_TOKEN=
